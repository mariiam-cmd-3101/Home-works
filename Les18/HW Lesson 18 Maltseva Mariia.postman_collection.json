  "item": [
    {
      "name": "Створення юзера з валідними даними про ім'я, вік, стать, місто.",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Set the user id as a collection variable\r",
              "var jsonData = pm.response.json();\r",
              "pm.collectionVariables.set(\"userId\", jsonData.id);\r",
              "\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"User city is correct\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.city).to.eql(\"Lviv\");\r",
              "});\r",
              "\r",
              "\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\": \"Princess\",\r\n    \"age\": \"23\",\r\n    \"gender\": \"female\",\r\n    \"city\": \"Lviv\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
